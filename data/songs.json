<script>

fetch("data/songs.json")
.then(res => res.json())
.then(songs => {

const container = document.getElementById("songs")

songs.forEach(song => {

const cover = `images/covers/${song.folder}.jpg`
const score = `scores/${song.folder}.pdf`

const div = document.createElement("div")
div.className = "song"

div.innerHTML = `

<img src="${cover}" alt="${song.title}" 
onerror="this.src='images/default-cover.jpg'">

<div class="song-info">

<h2>${song.title}</h2>

<a href="${score}" target="_blank">📄 Noten PDF</a>

<br><br>

<button onclick="playAll('${song.folder}')">
▶ Alle Stimmen starten
</button>

<h4>Sopran</h4>
<audio id="${song.folder}-soprano" controls
src="audio/${song.folder}/soprano.mp3"></audio>

<h4>Alt</h4>
<audio id="${song.folder}-alto" controls
src="audio/${song.folder}/alto.mp3"></audio>

<h4>Tenor</h4>
<audio id="${song.folder}-tenor" controls
src="audio/${song.folder}/tenor.mp3"></audio>

<h4>Bass</h4>
<audio id="${song.folder}-bass" controls
src="audio/${song.folder}/bass.mp3"></audio>

</div>
`

container.appendChild(div)

})

})

function playAll(song){

["soprano","alto","tenor","bass"].forEach(v => {

const audio = document.getElementById(song+"-"+v)

if(audio){
audio.currentTime = 0
audio.play()
}

})

}

</script>
