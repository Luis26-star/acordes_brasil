songs.forEach(song => {

const div = document.createElement("div")
div.className = "song"

const cover = song.cover ? song.cover : ""
const score = song.score ? song.score : "#"

div.innerHTML = `

<img src="${cover}" alt="${song.title}">

<div class="song-info">

<h2>${song.title}</h2>

<a href="${score}" target="_blank">📄 Noten PDF</a>

<h4>Sopran</h4>
<audio controls src="audio/${song.folder}/soprano.mp3"></audio>

<h4>Alt</h4>
<audio controls src="audio/${song.folder}/alto.mp3"></audio>

<h4>Tenor</h4>
<audio controls src="audio/${song.folder}/tenor.mp3"></audio>

<h4>Bass</h4>
<audio controls src="audio/${song.folder}/bass.mp3"></audio>

</div>

`

container.appendChild(div)

})
